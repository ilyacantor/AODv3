# =============================================================================
# AOD (Asset & Observability Discovery) — Environment Variables
# Copy to .env and fill in values. Secrets go in Render dashboard.
# =============================================================================

# --- Database ---
DATABASE_URL=                              # PostgreSQL connection string
SUPABASE_DB_URL=                           # Alias — same as DATABASE_URL

# --- Redis ---
REDIS_URL=                                 # Redis connection string

# --- LLM API Keys (at least one required) ---
GEMINI_API_KEY=                            # Google Gemini API key
OPENAI_API_KEY=                            # OpenAI API key

# --- Service URLs ---
AAM_URL=                                   # AAM service URL (AOD→AAM handoff)
AAM_API_URL=                               # AAM API URL alias
FARM_URL=                                  # Farm service URL
AOD_BASE_URL=                              # AOD's own public URL (self-reference)

# --- Farm Integration (optional) ---
FARM_SHARED_SECRET=                        # Shared secret for Farm requests
