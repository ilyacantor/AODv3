# Database Configuration
# At least one of these is required
SUPABASE_DB_URL=postgresql://user:password@host:port/database
# DATABASE_URL=postgresql://user:password@host:port/database

# LLM API Keys
# At least one of these is required
GEMINI_API_KEY=your_gemini_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here

# Farm Integration (Optional - only needed if using AOS Farm)
FARM_URL=https://your-farm-instance.onrender.com
FARM_SHARED_SECRET=your_shared_secret_here

# AAM Integration (Required for AOD→AAM handoff export)
AAM_URL=https://aos-aam.onrender.com
