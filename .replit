modules = ["python-3.11"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"
packages = ["libxcrypt"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "AOD Fresh Server"

[[workflows.workflow]]
name = "AOD Fresh Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd src && python -m uvicorn main:app --host 0.0.0.0 --port 5000 --reload"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "cd src && uvicorn main:app --host 0.0.0.0 --port 5000"]
build = ["bash", "-c", "pip install -e ."]
